# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ──────────────────────────────────────────────
# LM Studio — local LLM inference server
# ──────────────────────────────────────────────

# Base URL of your LM Studio OpenAI-compatible server
LM_STUDIO_HOST=http://localhost:1234/v1

# LM Studio does not require a real API key locally
LM_STUDIO_API_KEY=not-a-real-api-key

# The model you have loaded in LM Studio (e.g. nvidia/nemotron-3-nano-4b)
LM_STUDIO_MODEL_ID=your-model-id-here

# ──────────────────────────────────────────────
# Arize Phoenix — observability backend
# ──────────────────────────────────────────────

# Hostname where Phoenix is reachable (include scheme, no trailing slash)
ARIZE_PHOENIX_HOST=http://localhost

# HTTP port Phoenix is exposed on (Docker maps this to container port 6006)
ARIZE_PHOENIX_PORT=6007

# gRPC port (Docker maps this to container port 4317)
ARIZE_PHOENIX_GRPC_PORT=4318

